### Database Connection Info ###

# ============================================================
# LOCAL DEVELOPMENT DATABASE (docker-compose.yml)
# MariaDB 10.11
# DEV ONLY — do not use these credentials in production
# ============================================================
DB_HOST=localhost # Maps to localhost (port 3306)
DB_PORT=3307 # Maps to 3307:3306 in docker-compose
DB_NAME=paul_dev # Maps to MYSQL_DATABASE in MariaDB
DB_USER=paul # Maps to MYSQL_USER in MariaDB
DB_PASSWORD=paul_dev_password # Maps to MYSQL_PASSWORD in MariaDB

### Discord ###
DISCORD_TOKEN=

### Development ###
## Environment ##
# What environment the bot is running in (DEV, ACC, PROD) default = DEV
ENVIRONMENT=DEV
PORT=8080

## Logging ##
# If logs should be persisted to your local /logs directory (0 = no, 1 = yes) default = 1
LOGS_PERSISTENCE=1
# For how long logs should be kept in days (default = 7)
LOGS_MAX_AGE_IN_DAYS=1
